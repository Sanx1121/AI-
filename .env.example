# DashScope API key — set as an environment variable (do not commit secrets).
#
# PowerShell (current session):
#   $env:DASHSCOPE_API_KEY = "sk-your-key-here"
#
# PowerShell (persist for your user):
#   [Environment]::SetEnvironmentVariable("DASHSCOPE_API_KEY", "sk-your-key-here", "User")
#
# cmd (current session):
#   set DASHSCOPE_API_KEY=sk-your-key-here
#
# bash:
#   export DASHSCOPE_API_KEY=sk-your-key-here
